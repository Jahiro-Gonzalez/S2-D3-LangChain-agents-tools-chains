# Copia este archivo como .env y coloca tus claves reales.
# No subas .env a GitHub.

# Modelo de Groq por defecto.
# Si quieres otro, usa el nombre del modelo o el prefijo groq:.
# Ejemplos:
# MODEL_ID=llama-3.1-8b-instant
# MODEL_ID=groq:llama-3.1-70b-versatile
MODEL_ID=llama-3.1-8b-instant

# Solo necesitas la clave del proveedor que uses.
GROQ_API_KEY=tu_groq_api_key

# Opcionales si sigues probando otros proveedores.
GOOGLE_API_KEY=tu_google_api_key
OPENAI_API_KEY=tu_openai_api_key

# Opcional para trazas con LangSmith.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=tu_langsmith_api_key
LANGSMITH_PROJECT=s2-d3-langchain-agent
